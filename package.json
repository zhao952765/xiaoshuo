{
  "name": "private-novel-studio-pro",
  "version": "1.0.0",
  "description": "私人小说创作工作室 — AI 辅助小说创作桌面应用",
  "author": "Private Novel Studio Pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhao952765/xiaoshuo.git"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "novel",
    "writing",
    "ai",
    "desktop-app"
  ],
  "type": "module",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:all": "npm run build && npm run build:main && npm run build:preload",
    "preview": "vite preview",
    "lint": "eslint src",
    "pack": "electron-builder",
    "pack:win": "electron-builder --win --x64",
    "pack:mac": "electron-builder --mac",
    "pack:linux": "electron-builder --linux",
    "pack:portable": "electron-builder --win --x64 portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.private.novel.studio",
    "productName": "Private Novel Studio Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "assets",
      "prompts"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/123.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/123.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/123.ico",
      "uninstallerIcon": "assets/123.ico"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@xyflow/react": "^12.10.2",
    "antd": "^6.3.7",
    "autoprefixer": "^10.5.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "uuid": "^10.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  }
}
