{
  "name": "private-novel-studio-pro",
  "version": "1.0.0",
  "description": "私人小说创作工作室 — AI 辅助小说创作桌面应用",
  "author": "Private Novel Studio Pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/private-novel-studio-pro"
  },
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pack": "electron-builder",
    "pack:win": "electron-builder --win --x64",
    "pack:portable": "electron-builder --win --x64 portable"
  },
  "build": {
    "appId": "com.private.novel.studio",
    "productName": "Private Novel Studio Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "assets"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/123.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/123.ico",
      "uninstallerIcon": "assets/123.ico"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@xyflow/react": "^12.10.2",
    "antd": "^6.3.7",
    "autoprefixer": "^10.5.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  }
}
